NODE_ENV=development

# Dashboard
NEXT_PUBLIC_APP_NAME=SaaS Billing Platform
NEXT_PUBLIC_API_URL=http://localhost:4000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/billing_platform
MONGODB_DB=billing_platform

# Redis
REDIS_URL=redis://localhost:6379

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=billing-platform-invoices
SES_FROM_EMAIL=billing@example.com
SNS_ALERT_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:billing-alerts
